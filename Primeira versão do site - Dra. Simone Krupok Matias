<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dra. Simone Krupok Matias | Pneumologista Goiânia</title>
    <meta name="description" content="Dra. Simone Krupok Matias - Pneumologista e Tisiologista em Goiânia. Especialista em Fibrose Pulmonar, DPOC, Asma. Atendimento Online e Presencial.">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&family=Dancing+Script:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --rosa: #e84a7a;
            --rosa-claro: #f5a0b8;
            --rosa-suave: #fce4ec;
            --rosa-escuro: #c2185b;
            --azul: #1a3a5c;
            --azul-claro: #2c5282;
            --dourado: #c9a96e;
            --branco: #ffffff;
            --off-white: #faf8f5;
            --texto: #2d3748;
            --texto-claro: #718096;
        }
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', sans-serif;
            color: var(--texto);
            background: var(--off-white);
            line-height: 1.7;
            overflow-x: hidden;
        }
        
        h1, h2, h3, h4 { font-family: 'Playfair Display', serif; font-weight: 600; }
        
        .fonte-escrita { font-family: 'Dancing Script', cursive; }
        
        /* Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--off-white); }
        ::-webkit-scrollbar-thumb { background: var(--rosa); border-radius: 4px; }
        
        /* Navigation */
        nav {
            position: fixed;
            top: 0; width: 100%; z-index: 1000;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(232, 74, 122, 0.1);
            transition: all 0.3s ease;
        }
        
        nav.scrolled { box-shadow: 0 10px 40px rgba(232, 74, 122, 0.15); }
        
        .nav-container {
            max-width: 1200px; margin: 0 auto;
            display: flex; justify-content: space-between; align-items: center;
            padding: 1rem 2rem;
        }
        
        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem; font-weight: 700;
            color: var(--azul);
            text-decoration: none;
        }
        
        .logo .rosa { 
            color: var(--rosa); 
            font-family: 'Dancing Script', cursive; 
            font-weight: 700; 
        }
        
        .nav-links {
            display: flex; gap: 2.5rem; list-style: none;
        }
        
        .nav-links a {
            text-decoration: none; color: var(--texto);
            font-weight: 500; font-size: 0.95rem;
            position: relative; transition: color 0.3s;
        }
        
        .nav-links a::after {
            content: ''; position: absolute; bottom: -5px; left: 0;
            width: 0; height: 2px; background: var(--rosa);
            transition: width 0.3s;
        }
        
        .nav-links a:hover { color: var(--rosa); }
        .nav-links a:hover::after { width: 100%; }
        
        .mobile-menu-btn {
            display: none; background: none; border: none;
            font-size: 1.5rem; color: var(--rosa); cursor: pointer;
        }
        
        /* Hero Section */
        .hero {
            min-height: 100vh;
            display: flex; align-items: center;
            background: linear-gradient(135deg, var(--off-white) 0%, var(--rosa-suave) 50%, #e8f0f8 100%);
            position: relative; overflow: hidden;
            padding-top: 80px;
        }
        
        .hero::before {
            content: ''; position: absolute; top: -10%; right: -5%;
            width: 400px; height: 400px;
            background: var(--rosa);
            border-radius: 50%;
            opacity: 0.15;
            animation: float 8s ease-in-out infinite;
        }
        
        .hero::after {
            content: ''; position: absolute; bottom: -10%; left: -5%;
            width: 300px; height: 300px;
            background: var(--azul);
            border-radius: 50%;
            opacity: 0.1;
            animation: float 10s ease-in-out infinite reverse;
        }
        
        .hero-container {
            max-width: 1200px; margin: 0 auto;
            display: grid; grid-template-columns: 1fr 1fr;
            gap: 4rem; padding: 2rem; align-items: center;
            position: relative; z-index: 1;
        }
        
        .hero-content h1 {
            font-size: 3.2rem; color: var(--azul);
            line-height: 1.2; margin-bottom: 0.5rem;
            animation: fadeInUp 1s ease;
        }
        
        .hero-content .titulo-rosa {
            font-family: 'Dancing Script', cursive;
            font-size: 3.5rem; color: var(--rosa);
            margin-bottom: 1rem;
            animation: fadeInUp 1s ease 0.2s both;
        }
        
        .hero-content .subtitulo {
            font-size: 1.2rem; color: var(--texto-claro);
            margin-bottom: 0.5rem; font-weight: 400;
            animation: fadeInUp 1s ease 0.3s both;
        }
        
        .hero-content .destaque-texto {
            font-size: 1.4rem; color: var(--rosa-escuro);
            font-weight: 600; margin-bottom: 1.5rem;
            animation: fadeInUp 1s ease 0.4s both;
        }
        
        .badge-atendimento {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, var(--rosa), var(--rosa-escuro));
            color: var(--branco);
            padding: 0.8rem 1.5rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.95rem;
            box-shadow: 0 5px 20px rgba(232, 74, 122, 0.3);
            margin-bottom: 1.5rem;
            animation: fadeInUp 1s ease 0.3s both;
        }
        
        .hero-content .credentials {
            display: flex; flex-wrap: wrap; gap: 1rem;
            margin-bottom: 2.5rem;
            animation: fadeInUp 1s ease 0.5s both;
        }
        
        .credential-badge {
            background: linear-gradient(135deg, var(--rosa), var(--rosa-escuro));
            padding: 0.6rem 1.2rem; border-radius: 50px;
            color: var(--branco); font-size: 0.85rem;
            box-shadow: 0 5px 15px rgba(232, 74, 122, 0.3);
        }
        
        .credential-badge.azul {
            background: linear-gradient(135deg, var(--azul), var(--azul-claro));
            box-shadow: 0 5px 15px rgba(26, 58, 92, 0.3);
        }
        
        .hero-buttons {
            display: flex; gap: 1rem;
            animation: fadeInUp 1s ease 0.6s both;
        }
        
        .btn {
            padding: 1rem 2.5rem; border-radius: 50px;
            text-decoration: none; font-weight: 600;
            transition: all 0.3s ease; display: inline-flex;
            align-items: center; gap: 0.5rem; font-size: 1rem;
        }
        
        .btn-rosa {
            background: linear-gradient(135deg, var(--rosa), var(--rosa-escuro));
            color: var(--branco);
            box-shadow: 0 10px 30px rgba(232, 74, 122, 0.3);
        }
        
        .btn-rosa:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(232, 74, 122, 0.4);
        }
        
        .btn-outline {
            background: transparent; color: var(--rosa);
            border: 2px solid var(--rosa);
        }
        
        .btn-outline:hover {
            background: var(--rosa); color: var(--branco);
        }
        
        .hero-image {
            position: relative; animation: fadeIn 1.5s ease;
            display: flex; justify-content: center;
        }
        
        .hero-image .image-placeholder {
            width: 100%; max-width: 400px; aspect-ratio: 1;
            background: linear-gradient(135deg, rgba(232,74,122,0.2), rgba(26,58,92,0.2));
            border-radius: 30px;
            border: 3px solid var(--rosa);
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            color: var(--rosa);
            font-size: 5rem;
            backdrop-filter: blur(10px);
        }
        
        .hero-image .image-placeholder p {
            font-size: 1rem; margin-top: 1rem;
            font-family: 'Inter', sans-serif;
            color: var(--azul);
        }
        
        .floating-card {
            position: absolute;
            background: var(--branco);
            padding: 1.2rem 1.5rem; border-radius: 20px;
            box-shadow: 0 10px 40px rgba(232, 74, 122, 0.15);
            animation: float 6s ease-in-out infinite;
        }
        
        .floating-card.card-1 {
            bottom: 10%; left: -10%;
            animation-delay: 0s;
        }
        
        .floating-card.card-2 {
            top: 10%; right: -5%;
            animation-delay: 2s;
        }
        
        .floating-card .icon {
            font-size: 1.5rem; color: var(--rosa);
            margin-bottom: 0.3rem;
        }
        
        .floating-card .number {
            font-size: 1.8rem; font-weight: 700;
            color: var(--azul); font-family: 'Playfair Display', serif;
        }
        
        .floating-card .label {
            font-size: 0.8rem; color: var(--texto-claro);
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }
        
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        
        /* Section Styles */
        section { padding: 6rem 2rem; }
        
        .section-container {
            max-width: 1200px; margin: 0 auto;
        }
        
        .section-header {
            text-align: center; margin-bottom: 4rem;
        }
        
        .section-header h2 {
            font-size: 2.5rem; color: var(--azul);
            margin-bottom: 0.5rem;
        }
        
        .section-header .titulo-rosa {
            font-family: 'Dancing Script', cursive;
            font-size: 2rem; color: var(--rosa);
        }
        
        .section-header .divider {
            width: 80px; height: 4px;
            background: linear-gradient(90deg, var(--rosa), var(--dourado));
            margin: 1rem auto; border-radius: 2px;
        }
        
        .section-header p {
            color: var(--texto-claro); font-size: 1.1rem;
            max-width: 600px; margin: 1rem auto 0;
        }
        
        /* About Section */
        .about {
            background: var(--branco);
            position: relative;
        }
        
        .about::before {
            content: ''; position: absolute; top: 0; right: 0;
            width: 200px; height: 200px;
            background: var(--rosa);
            border-radius: 0 0 0 200px;
            opacity: 0.05;
        }
        
        .about-grid {
            display: grid; grid-template-columns: 1fr 1fr;
            gap: 4rem; align-items: center;
        }
        
        .about-image {
            position: relative;
        }
        
        .about-image .img-frame {
            background: linear-gradient(135deg, var(--rosa), var(--rosa-claro));
            border-radius: 30px; padding: 1rem;
            position: relative;
        }
        
        .about-image .img-placeholder {
            background: var(--branco); border-radius: 20px;
            aspect-ratio: 3/4; display: flex;
            flex-direction: column; align-items: center;
            justify-content: center; color: var(--rosa);
            font-size: 4rem;
        }
        
        .about-image .img-placeholder p {
            font-size: 0.9rem; color: var(--texto-claro);
            font-family: 'Inter', sans-serif; margin-top: 0.5rem;
        }
        
        .about-content h3 {
            font-size: 2rem; color: var(--azul);
            margin-bottom: 0.5rem;
        }
        
        .about-content .subtitulo-rosa {
            font-family: 'Dancing Script', cursive;
            font-size: 1.8rem; color: var(--rosa);
            margin-bottom: 1.5rem;
        }
        
        .about-content p {
            color: var(--texto-claro); margin-bottom: 1.5rem;
            font-size: 1.05rem;
        }
        
        .about-content p strong {
            color: var(--azul);
        }
        
        .about-stats {
            display: grid; grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem; margin-top: 2rem;
        }
        
        .stat-item {
            text-align: center; padding: 1.5rem;
            background: var(--rosa-suave); border-radius: 20px;
            transition: transform 0.3s;
            border: 2px solid transparent;
        }
        
        .stat-item:hover {
            transform: translateY(-5px);
            border-color: var(--rosa);
        }
        
        .stat-item .number {
            font-size: 2rem; font-weight: 700;
            color: var(--rosa); font-family: 'Playfair Display', serif;
        }
        
        .stat-item .label {
            font-size: 0.85rem; color: var(--texto-claro);
            margin-top: 0.3rem;
        }
        
        /* Services Section */
        .services {
            background: linear-gradient(180deg, var(--off-white) 0%, var(--rosa-suave) 100%);
            position: relative;
        }
        
        .services::before {
            content: ''; position: absolute; bottom: 0; left: 0;
            width: 150px; height: 150px;
            background: var(--azul);
            border-radius: 0 150px 0 0;
            opacity: 0.05;
        }
        
        .services-grid {
            display: grid; grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }
        
        .service-card {
            background: var(--branco); border-radius: 25px;
            padding: 2.5rem; transition: all 0.4s ease;
            border: 2px solid transparent;
            position: relative; overflow: hidden;
        }
        
        .service-card::before {
            content: ''; position: absolute; top: 0; left: 0;
            width: 100%; height: 5px;
            background: linear-gradient(90deg, var(--rosa), var(--dourado));
            transform: scaleX(0); transform-origin: left;
            transition: transform 0.4s ease;
        }
        
        .service-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 40px rgba(232, 74, 122, 0.15);
            border-color: var(--rosa-claro);
        }
        
        .service-card:hover::before { transform: scaleX(1); }
        
        .service-card .icon {
            width: 70px; height: 70px;
            background: linear-gradient(135deg, var(--rosa), var(--rosa-escuro));
            border-radius: 20px; display: flex;
            align-items: center; justify-content: center;
            font-size: 1.8rem; color: var(--branco);
            margin-bottom: 1.5rem;
            box-shadow: 0 10px 20px rgba(232, 74, 122, 0.2);
        }
        
        .service-card h3 {
            font-size: 1.3rem; color: var(--azul);
            margin-bottom: 1rem;
        }
        
        .service-card p {
            color: var(--texto-claro); font-size: 0.95rem;
        }
        
        /* Publications Section */
        .publications { background: var(--branco); }
        
        .pub-grid {
            display: grid; gap: 1.5rem;
        }
        
        .pub-card {
            display: flex; gap: 1.5rem; padding: 2rem;
            background: var(--off-white); border-radius: 20px;
            transition: all 0.3s;
            border-left: 5px solid var(--rosa);
            position: relative;
            overflow: hidden;
        }
        
        .pub-card::after {
            content: ''; position: absolute; top: 0; right: 0;
            width: 100px; height: 100px;
            background: var(--rosa);
            border-radius: 0 0 0 100px;
            opacity: 0.05;
        }
        
        .pub-card:hover {
            transform: translateX(10px);
            box-shadow: 0 10px 40px rgba(232, 74, 122, 0.15);
        }
        
        .pub-card .pub-icon {
            font-size: 2.5rem; color: var(--rosa);
            flex-shrink: 0;
        }
        
        .pub-card .pub-content h4 {
            font-size: 1.1rem; color: var(--azul);
            margin-bottom: 0.5rem;
        }
        
        .pub-card .pub-content p {
            color: var(--texto-claro); font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }
        
        .pub-card .pub-content .journal {
            font-size: 0.85rem;
            background: linear-gradient(135deg, var(--rosa), var(--rosa-escuro));
            color: var(--branco); font-weight: 600;
            padding: 0.3rem 0.8rem; border-radius: 20px;
            display: inline-block;
        }
        
        /* Contact Section */
        .contact {
            background: linear-gradient(135deg, var(--azul) 0%, var(--azul-claro) 100%);
            color: var(--branco);
            position: relative;
            overflow: hidden;
        }
        
        .contact::before {
            content: ''; position: absolute; top: -100px; right: -100px;
            width: 300px; height: 300px;
            background: var(--rosa);
            border-radius: 50%;
            opacity: 0.1;
        }
        
        .contact::after {
            content: ''; position: absolute; bottom: -50px; left: -50px;
            width: 200px; height: 200px;
            background: var(--dourado);
            border-radius: 50%;
            opacity: 0.1;
        }
        
        .contact .section-header h2,
        .contact .section-header p { color: var(--branco); }
        
        .contact .section-header .divider {
            background: linear-gradient(90deg, var(--rosa), var(--dourado));
        }
        
        .contact-grid {
            display: grid; grid-template-columns: 1fr 1fr;
            gap: 4rem; align-items: start;
            position: relative; z-index: 1;
        }
        
        .contact-info h3 {
            font-size: 1.8rem; margin-bottom: 1.5rem;
        }
        
        .contact-info p {
            color: rgba(255,255,255,0.9); margin-bottom: 2rem;
        }
        
        .contact-item {
            display: flex; align-items: center; gap: 1rem;
            margin-bottom: 1.5rem;
        }
        
        .contact-item .icon {
            width: 50px; height: 50px;
            background: linear-gradient(135deg, var(--rosa), var(--rosa-escuro));
            border-radius: 15px; display: flex;
            align-items: center; justify-content: center;
            font-size: 1.2rem; color: var(--branco);
            flex-shrink: 0;
            box-shadow: 0 5px 15px rgba(232, 74, 122, 0.3);
        }
        
        .contact-item .info h4 {
            font-size: 0.9rem; color: var(--rosa-claro);
            margin-bottom: 0.2rem; font-family: 'Inter', sans-serif;
            font-weight: 500;
        }
        
        .contact-item .info p,
        .contact-item .info a {
            color: var(--branco); text-decoration: none;
            font-size: 1rem; transition: color 0.3s;
        }
        
        .contact-item .info a:hover { color: var(--rosa-claro); }
        
        .contact-form {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(20px);
            border-radius: 30px; padding: 2.5rem;
            border: 1px solid rgba(255,255,255,0.2);
        }
        
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-group label {
            display: block; margin-bottom: 0.5rem;
            color: var(--rosa-claro); font-size: 0.9rem;
            font-weight: 500;
        }
        
        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%; padding: 1rem 1.2rem;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 15px; background: rgba(255,255,255,0.1);
            color: var(--branco); font-size: 1rem;
            transition: all 0.3s; font-family: 'Inter', sans-serif;
        }
        
        .form-group input::placeholder,
        .form-group textarea::placeholder { color: rgba(255,255,255,0.5); }
        
        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none; border-color: var(--rosa);
            background: rgba(255,255,255,0.15);
        }
        
        .form-group textarea { resize: vertical; min-height: 120px; }
        
        .submit-btn {
            width: 100%; padding: 1.2rem;
            background: linear-gradient(135deg, var(--rosa), var(--rosa-escuro));
            color: var(--branco); border: none;
            border-radius: 15px;
            font-size: 1.1rem; font-weight: 700;
            cursor: pointer; transition: all 0.3s;
            font-family: 'Inter', sans-serif;
            box-shadow: 0 10px 30px rgba(232, 74, 122, 0.3);
        }
        
        .submit-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(232, 74, 122, 0.4);
        }
        
        /* Footer */
        footer {
            background: var(--azul);
            color: rgba(255,255,255,0.7);
            padding: 3rem 2rem 2rem;
            text-align: center;
        }
        
        footer .footer-content {
            max-width: 1200px; margin: 0 auto;
        }
        
        footer .logo-footer {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem; color: var(--branco);
            margin-bottom: 0.5rem;
        }
        
        footer .logo-footer .rosa {
            font-family: 'Dancing Script', cursive;
            color: var(--rosa);
        }
        
        footer p { margin-bottom: 1rem; font-size: 0.9rem; }
        
        footer .social-links {
            display: flex; justify-content: center; gap: 1rem;
            margin: 1.5rem 0;
        }
        
        footer .social-links a {
            width: 45px; height: 45px;
            background: linear-gradient(135deg, var(--rosa), var(--rosa-escuro));
            border-radius: 50%; display: flex;
            align-items: center; justify-content: center;
            color: var(--branco); text-decoration: none;
            transition: all 0.3s; font-size: 1.1rem;
            box-shadow: 0 5px 15px rgba(232, 74, 122, 0.3);
        }
        
        footer .social-links a:hover {
            transform: translateY(-3px) scale(1.1);
            box-shadow: 0 10px 25px rgba(232, 74, 122, 0.4);
        }
        
        footer .copyright {
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 2rem; margin-top: 2rem;
            font-size: 0.85rem; color: rgba(255,255,255,0.5);
        }
        
        /* WhatsApp Float */
        .whatsapp-float {
            position: fixed; bottom: 30px; right: 30px;
            width: 60px; height: 60px;
            background: linear-gradient(135deg, #25d366, #128c7e);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: var(--branco); font-size: 1.8rem;
            text-decoration: none;
            box-shadow: 0 10px 30px rgba(37,211,102,0.3);
            transition: all 0.3s; z-index: 999;
            animation: pulse-whatsapp 2s infinite;
        }
        
        .whatsapp-float:hover {
            transform: scale(1.1);
            box-shadow: 0 15px 40px rgba(37,211,102,0.4);
        }
        
        @keyframes pulse-whatsapp {
            0%, 100% { box-shadow: 0 10px 30px rgba(37,211,102,0.3); }
            50% { box-shadow: 0 10px 30px rgba(37,211,102,0.6); }
        }
        
        /* Responsive */
        @media (max-width: 992px) {
            .hero-container,
            .about-grid,
            .contact-grid { grid-template-columns: 1fr; }
            
            .hero-content h1 { font-size: 2.2rem; }
            .hero-content .titulo-rosa { font-size: 2.5rem; }
            
